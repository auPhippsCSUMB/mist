<%- include('partials/head', { title: game[0].name }) %>
    <div class="card soft-card">
        <div class="card-body p-4 p-md-5">
            <div class="row">
                <div class="col">
                    <% if (finalCover[0]) { %>
                    <img src="https://images.igdb.com/igdb/image/upload/t_cover_big/<%=finalCover[0].image_id%>.jpg" class="d-block"
                        width="300">
                    <% } else { %>
                        <img src="" alt="No Image Available" class="d-block"
                        width="300">
                    <% } %>
                </div>
                <div class="col">
                    <h1>
                        <%=game[0].name%>
                    </h1>
                    <hr>
                    <h2>Rating: <%=Math.round(game[0].rating)%>/100
                    </h2>
                    <h2><%=game[0].rating_count%> Reviews
                    </h2>
                    <br>
                    <p><%=game[0].storyline%>
                    </p>
                </div>
            </div>
            <hr>
            <h1 class="text-center">Game Pictures</h1>
            <br>
            <% if (screenshots[0]) { %>
                    <div id="carouselExampleSlidesOnly" class="carousel slide" data-ride="carousel">
                        <div class="carousel-inner">
                            <div class="carousel-item active">
                                <img class="d-block w-100" src="https://images.igdb.com/igdb/image/upload/t_screenshot_big/<%=screenshots[0].image_id%>.jpg" alt="First slide">
                            </div>
                            <% for (let i=1; i < screenshots.length; i++) { %>
                            <div class="carousel-item">
                                <img class="d-block w-100" src="https://images.igdb.com/igdb/image/upload/t_screenshot_big/<%=screenshots[i].image_id%>.jpg" alt="<%=screenshots[0].image_id%>">
                            </div>
                            <% } %>
                        </div>
                    </div>
            <% } else { %>
                <img class="d-block w-100" src="" alt="No Pictures Available">
            <% } %>

        </div>
        <%- include('partials/footer') %>