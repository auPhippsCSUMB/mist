<%- include('partials/head', { title: 'My Friends' }) %>
    <div class="card soft-card">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h1 class="h3 section-title mb-0">My Friends</h1>
                <a href="/addFriends" class="btn btn-primary btn-sm">+ Add Friends</a>
            </div>
            <% if (friends && friends.length> 0) { %>
                <ul class="list-group list-group-flush">
                    <% friends.forEach(friend=> { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                            <div>
                                <strong>
                                    <%= friend.username %>
                                </strong>
                                <span class="text-muted ms-2">
                                    <%= friend.firstName %>
                                        <%= friend.lastName %>
                                </span>
                            </div>
                            <div>
                                <a href="/friendsWishlist/<%= friend.userID %>" class="btn btn-sm btn-outline-primary">
                                    View Wishlist
                                </a>

                                <form action="/removeFriend" method="POST" style="display:inline;">
                                    <input type="hidden" name="friendUserID" value="<%= friend.userID %>">

                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        Remove
                                    </button>
                                </form>
                            </div>
                        </li>
                        <% }) %>
                </ul>
                <% } else { %>
                    <p class="text-muted">You have no friends yet. <a href="/addFriends">Add some!</a></p>
                    <% } %>
        </div>
    </div>
    <%- include('partials/footer') %>