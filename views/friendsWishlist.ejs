<%- include('partials/head', { title: 'Friends Wishlists' }) %>
<div class="card soft-card">
	<div class="card-body p-4">
		<div class="d-flex justify-content-between align-items-center mb-3">
			<h1 class="h3 section-title mb-0">Friends' Wishlist</h1>
			<a href="/friends" class="btn btn-outline-secondary btn-sm">Back to Friends</a>
		</div>
		<% if (wishlist && wishlist.length > 0) { %>
			<ul class="list-group list-group-flush">
				<% wishlist.forEach(game => { %>
					<li class="list-group-item d-flex justify-content-between align-items-center px-0">
						<div>
							<strong><%= game.title %></strong>
							<span class="text-muted ms-2"><%= game.genre %></span>
						</div>
						<span class="badge text-bg-secondary"><%= game.likes %> likes</span>
					</li>
				<% }) %>
			</ul>
		<% } else { %>
			<p class="text-muted">This friend has no games in their wishlist.</p>
		<% } %>
	</div>
</div>
<%- include('partials/footer') %>
