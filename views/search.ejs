<%- include('partials/head', { title: 'Search' }) %>
<div class="card soft-card mb-4">
	<div class="card-body p-4">
		<h1 class="h3 section-title mb-3">Search Games</h1>
		<form class="row g-3" method="POST" action="/search">
			<div class="col-md-9">
				<label for="gameName" class="form-label">Game title</label>
				<input type="text" class="form-control" id="gameName" name="gameName" placeholder="e.g. Hollow Knight" required>
			</div>
			<div class="col-md-3 d-grid align-self-end">
				<button type="submit" class="btn btn-primary">Search</button>
			</div>
		</form>
	</div>
</div>

<div class="card soft-card">
	<div class="card-body p-4">
		<h2 class="h5 mb-3">Results</h2>
		<% if (games && games.length > 0) { %>
			<div class="row row-cols-2 row-cols-md-4 g-3">
				<% games.forEach(game => { %>
					<div class="col">
						<div class="card soft-card h-100">
							<% if (game.cover && game.cover.url) { %>
								<img src="https:<%= game.cover.url.replace('t_thumb','t_cover_big') %>" class="card-img-top" alt="<%= game.name %>" style="object-fit:cover;height:180px;">
							<% } %>
							<div class="card-body p-2">
								<p class="card-title fw-semibold mb-2"><%= game.name %></p>
								<form action="/addToWishlist" method="POST">
									<input type="hidden" name="gameID" value="<%= game.id %>">
									<input type="hidden" name="title" value="<%= game.name %>">
									<button type="submit" class="btn btn-sm btn-outline-primary w-100">+ Wishlist</button>
								</form>
							</div>
						</div>
					</div>
				<% }) %>
			</div>
		<% } else { %>
			<p class="text-muted">No results yet. Run a search to see games.</p>
		<% } %>
	</div>
</div>
<%- include('partials/footer') %>
