<%- include('partials/head', { title: 'Add Friends' }) %>
<div class="row g-3">
	<div class="col-lg-6">
		<div class="card soft-card h-100">
			<div class="card-body p-4">
				<h1 class="h4 section-title mb-3">Find Friends</h1>
				<form method="post" action="/addFriends" class="row g-3">
					<div class="col-12">
						<label for="friendName" class="form-label">Username or email</label>
						<input type="text" class="form-control" id="friendName" name="friendName" placeholder="Search by username">
					</div>
					<div class="col-12">
						<button type="submit" class="btn btn-primary">Send Request</button>
					</div>
				</form>
			</div>
		</div>
	</div>

	<div class="col-lg-6">
		<div class="card soft-card h-100">
			<div class="card-body p-4">
				<h2 class="h5 mb-3">Friend Requests</h2>
				<ul class="list-group">
					<li class="list-group-item d-flex justify-content-between align-items-center">
						gamer_anna
						<button class="btn btn-sm btn-outline-success">Accept</button>
					</li>
					<li class="list-group-item d-flex justify-content-between align-items-center">
						jayplays
						<button class="btn btn-sm btn-outline-success">Accept</button>
					</li>
				</ul>
			</div>
		</div>
	</div>
</div>
<%- include('partials/footer') %>
