<%- include('partials/head', { title: 'Profile' }) %>
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card soft-card h-100">
                <div class="card-body">
                    <h1 class="h4 section-title mb-3">Your Profile</h1>
                    <p class="mb-1"><strong>Username:</strong>
                        <%= userInfo.username %>
                    </p>
                    <p class="mb-1"><strong>Name:</strong>
                        <%= userInfo.firstName %>
                            <%= userInfo.lastName %>
                    </p>
                    <p class="mb-3"><strong>Friends:</strong>
                        <%= friendCount %>
                    </p>
                    <a href="/editProfile" class="btn btn-outline-primary btn-sm">Edit Profile</a>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card soft-card h-100">
                <div class="card-body">
                    <h2 class="h5 mb-3">Activity</h2>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item px-0">Added Stellar Odyssey to wishlist</li>
                        <li class="list-group-item px-0">Followed Alex</li>
                        <li class="list-group-item px-0">Reviewed Night Run</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="card soft-card">
        <div class="card-body p-4">
            <h2 class="h5 mb-3">Your Wishlist</h2>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Game</th>
                            <th>Platform</th>
                            <th>Priority</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (wishlist.length> 0) { %>
                             <% wishlist.forEach(game=> { %>
                                <tr>
                                    <td>
                                        <%= game.title %>
                                    </td>
                                    <td>
                                        <%= game.genre %>
                                    </td>
                                    <td><span class="badge text-bg-primary">Wishlist</span></td>
                                </tr>
                                <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="3">Your wishlist is empty.</td>
                                        </tr>
                                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <%- include('partials/footer') %>